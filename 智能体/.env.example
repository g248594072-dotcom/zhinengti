# 复制本文件为 .env 并填写 MYSQL_PASSWORD（勿提交 .env 到 Git）
# 应用与 MySQL 在同一台 1Panel 服务器上时，HOST 保持 127.0.0.1 即可

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=customer_ai
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=customer_ai
MYSQL_CHARSET=utf8mb4

# 飞书群机器人 Webhook（每日成交学习完成后推送日报，可选）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_token_here
